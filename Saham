```{r}
#=========================================
# Perhitungan Nilai Ai dan Bi
#=========================================
tabel_ERB$Varians_Residual <-
  var_residual[tabel_ERB$Saham]

tabel_ERB$Ai <-
  ((tabel_ERB$ER - Rf) *
     tabel_ERB$Beta) /
  tabel_ERB$Varians_Residual

tabel_ERB$Bi <-
  (tabel_ERB$Beta^2) /
  tabel_ERB$Varians_Residual
tabel_ERB
```
```{r}
#=========================================
# Perhitungan Ci
#=========================================
Ci <- c()
for(i in 1:nrow(tabel_ERB)){
  sumA <- sum(tabel_ERB$Ai[1:i])
  sumB <- sum(tabel_ERB$Bi[1:i])
  Ci[i] <-
    (var_market * sumA) /
    (1 + var_market * sumB)
}

tabel_ERB$Ci <- Ci
