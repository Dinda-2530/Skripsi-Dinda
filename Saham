```{r}
# Menghitung Return Saham 
return_saham = diff(log(as.matrix(Saham)))
return_saham
colnames(return_saham) = colnames(Saham)

#Menghitung Return Pasar 
return_pasar <- (IHSG[-1] - IHSG[-length(IHSG)]) / IHSG[-length(IHSG)]
ER_market <- mean(return_pasar)
var_market <- var(return_pasar)
tabel_pasar <- data.frame(
  Keterangan = c("Expected Return Pasar", "Varians Return Pasar"),
  Nilai = c(ER_market, var_market)
)
tabel_pasar
```
```{r}
# Menghitung Kovarian 
cov_saham_pasar <- sapply(1:ncol(return_saham), function(i){
  cov(return_saham[,i], return_pasar)
})
names(cov_saham_pasar) <- colnames(return_saham)
tabel_cov <- data.frame(
  Saham = colnames(return_saham),
  Covariance = cov_saham_pasar
)
tabel_cov
```
```{r}
# Menghitung Expected Return Saham
ER_saham <- colMeans(return_saham)
tabel_ER_saham <- data.frame(
  Saham = colnames(return_saham),
  Expected_Return = ER_saham
)
tabel_ER_saham
```
```{r}
# Menghitung Beta dan Alpha
beta <- cov_saham_pasar / var_market
alpha <- ER_saham - beta * ER_market
tabel_alpha_beta <- data.frame(
  Saham = colnames(return_saham),
  Beta = beta,
  Alpha = alpha
)
tabel_alpha_beta
```
```{r}
# Pembentukan Model Single Index Model
model_SIM <- lapply(1:ncol(return_saham), function(i){
  lm(return_saham[,i] ~ return_pasar)
})
model_SIM
```
```{r}
# Menghitung Parameter Asumsi SIM
residual_saham <- sapply(model_SIM, residuals)
colnames(residual_saham) <- colnames(return_saham)
residual_saham

# Varians Residual
var_residual <- apply(residual_saham, 2, var)
tabel_var_residual <- data.frame(
  Saham = colnames(residual_saham),
  Varian_Residual = var_residual
)
tabel_var_residual

# Kovarian antar residual saham
cov_residual <- cov(residual_saham)
library(reshape2)
tabel_cov_residual <- melt(cov_residual)
colnames(tabel_cov_residual) <- c("Saham1", "Saham2", "Covariance")
tabel_cov_residual

# Kovarian residual dengan return pasar
cov_residual_pasar <- sapply(1:ncol(residual_saham), function(i){
  cov(residual_saham[,i], return_pasar)
})
tabel_cov_pasar <- data.frame(
  Saham = colnames(residual_saham),
  Covariance = cov_residual_pasar
)
tabel_cov_pasar
```
```{r}
# Uji Asumsi Single Index Model

# 1. Residual Berdistribusi Normal
library(nortest)
pvalue_normalitas <- sapply(1:ncol(residual_saham), function(i){
  lillie.test(residual_saham[,i])$p.value
})
normalitas <- ifelse(pvalue_normalitas > 0.05,
                     "Memenuhi",
                     "Tidak Memenuhi")

# 2. Kovarian antar residual bernilai nol
korelasi_residual <- sapply(1:ncol(residual_saham), function(i){
  hasil <- sapply(1:ncol(residual_saham), function(j){
    if(i == j){
      return(NA)
    } else{
      cor.test(residual_saham[,i], residual_saham[,j])$p.value
    }
  })
  if(any(hasil < 0.05, na.rm = TRUE)){
    "Tidak Memenuhi"
  } else{
    "Memenuhi"
  }
})

# 3. Kovarian antar residual saham dengan return pasar
korelasi_IHSG <- sapply(1:ncol(residual_saham), function(i){
  test <- cor.test(residual_saham[,i], return_pasar)
  if(test$p.value > 0.05){
    "Memenuhi"
  } else{
    "Tidak Memenuhi"
  }
})

# Tabel Uji Asumsi
Uji_Asumsi <- data.frame(
  No = 1:ncol(residual_saham),
  Saham = colnames(residual_saham),
  Normalitas = normalitas,
  Korelasi_Antar_Residual = korelasi_residual,
  Korelasi_Residual_IHSG = korelasi_IHSG,
  row.names = NULL
)
Uji_Asumsi
```
```{r}
# Tabel Saham yang lolos 3 Uji Asumsi SIM
library(dplyr)
library(tidyverse)
saham_lolos <- Uji_Asumsi %>%
  filter(Normalitas == "Memenuhi",
         Korelasi_Antar_Residual == "Memenuhi",
         Korelasi_Residual_IHSG == "Memenuhi")
saham_lolos
```
```{r}
# Tabel Nilai ERB
kode_lolos <- saham_lolos$Saham
return_lolos <- return_saham[, kode_lolos]
ER <- colMeans(return_lolos)
RBR <- 0.000216
beta_lolos <- beta[match(kode_lolos, names(beta))]
ERB <- (ER - RBR) / beta_lolos
tabel_ERB <- data.frame(
  Saham = kode_lolos,
  ERB = ERB,
  Beta = beta_lolos,
  ER = ER
)
tabel_ERB

# Tabel Nilai ERB, Beta, dan Expected Return
ERB_aja <- data.frame(
  Saham = kode_lolos,
  ERB = ERB
)
ERB_aja
```
```{r}
# Pengurutan Nilai ERB Terbesar ke Terkecil
tabel_ERB <- tabel_ERB %>%
  arrange(desc(ERB))
tabel_ERB
```
```{r}
# Perhitungan Nilai Ai dan Bi
var_residual <- apply(residual_saham[, kode_lolos], 2, var)
tabel_ERB$var_residual <- var_residual[tabel_ERB$Saham]
tabel_ERB$Ai <- ((tabel_ERB$ER - RBR) * tabel_ERB$Beta) / tabel_ERB$var_residual
tabel_ERB$Bi <- (tabel_ERB$Beta^2) / tabel_ERB$var_residual
tabel_ERB
```
```{r}
# Perhitungan Nilai Ci
var_market <- var(return_pasar)
Ci <- c()
for(i in 1:nrow(tabel_ERB)){
  sumA <- sum(tabel_ERB$Ai[1:i])
  sumB <- sum(tabel_ERB$Bi[1:i])
  Ci[i] <- (var_market * sumA) / (1 + var_market * sumB)
}
tabel_ERB$Ci <- Ci
tabel_ERB
```
```{r}
# Penentuan Cut off-point (C*)
C_star <- max(tabel_ERB$Ci[tabel_ERB$ERB >= tabel_ERB$Ci])
C_star
portofolio_optimal <- tabel_ERB %>%
  filter(ERB >= C_star)
portofolio_optimal
```
```{r}
# Perhitungan Bobot
portofolio_optimal$Zi <- (portofolio_optimal$Beta / portofolio_optimal$var_residual) *
                        (portofolio_optimal$ERB - C_star)
total_Zi <- sum(portofolio_optimal$Zi)
portofolio_optimal$wi <- portofolio_optimal$Zi / total_Zi
tabel_bobot <- data.frame(
  No = 1:nrow(portofolio_optimal),
  Saham = portofolio_optimal$Saham,
  Zi = round(portofolio_optimal$Zi, 4),
  wi = round(portofolio_optimal$wi, 4)
)
tabel_bobot
```
```{r}
# Perhitungan Persentil 
V0 <- 100000000   
alpha <- 0.05     
return_portofolio <- as.matrix(return_lolos[, portofolio_optimal$Saham]) %*% 
                     portofolio_optimal$wi
return_portofolio <- as.vector(return_portofolio)
P_alpha <- quantile(return_portofolio, probs = 0.05)
P_alpha
```
```{r}
# VaR Portofolio 
T_horizon <- c(1, 5, 21, 252)
VaR <- -V0 * P_alpha * sqrt(T_horizon)
VaR_Portofolio <- data.frame(
  Horizon = c("1 Hari", "5 Hari (1 Minggu)", "21 Hari (1 Bulan)", "252 Hari (1 Tahun)"),
  T = T_horizon,
  VaR = round(VaR, 0)
)
VaR_Portofolio
```
```{r}
# Persentil Tiap Saham pada Portofolio Optimal
return_optimal <- return_saham[, portofolio_optimal$Saham, drop = FALSE]
persentil_saham <- apply(return_optimal, 2, function(x){
  quantile(x, probs = alpha, na.rm = TRUE)
})
tabel_persentil <- data.frame(
  No = 1:length(persentil_saham),
  Saham = names(persentil_saham),
  Persentil = round(persentil_saham, 4)
)
tabel_persentil
```
```{r}
# VaR Saham
T_horizon <- c(1, 5, 21, 252)
VaR_saham <- sapply(T_horizon, function(T){
  -V0 * persentil_saham * sqrt(T)
})
format_rp <- function(x){
  paste0("Rp ", format(round(x,0), big.mark = ".", decimal.mark = ","))
}
VaR_Saham <- data.frame(
  No = 1:length(persentil_saham),
  Saham = names(persentil_saham),
  "1 Hari" = format_rp(VaR_saham[,1]),
  "5 Hari" = format_rp(VaR_saham[,2]),
  "21 Hari" = format_rp(VaR_saham[,3]),
  "252 Hari" = format_rp(VaR_saham[,4]),
  check.names = FALSE   
)
VaR_Saham
