```{r}
#=========================================
# Fungsi Kupiec Test
#=========================================
kupiec_test <- function(
    returns,
    VaR_return,
    alpha = 0.05
){

  violation <- ifelse(
    returns < -VaR_return,
    1,
    0
  )
  
  g <- sum(violation)
  n <- length(returns)
  p_hat <- g / n
  if(g == 0 || g == n){
    LR_POF <- NA
  } else {

    LR_POF <- -2 * log(
      ((1-alpha)^(n-g) * alpha^g) /
      ((1-p_hat)^(n-g) * p_hat^g)
    )
  }

  Chi_Kritis <- qchisq(
    0.95,
    df = 1
  )

  Keputusan <- ifelse(
    LR_POF < Chi_Kritis,
    "Valid",
    "Tidak Valid"
  )
 
  data.frame(
    Observasi = n,
    Violation = g,
    Proporsi = round(p_hat,4),
    LR_POF = round(LR_POF,4),
    Chi_Kritis = round(Chi_Kritis,4),
    Keputusan = Keputusan
  )
}

